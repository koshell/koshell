{
  "name": "koshell",
  "version": "0.1.0",
  "description": "Human-centric shared terminal: Rust terminal-core beside a Node AI daemon.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "format": "prettier . --write --list-different",
    "format:check": "prettier . --check",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,cts,mts,json,jsonc,css,scss,md,yml,yaml}": "prettier --write --list-different"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4"
  }
}
