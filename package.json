{
  "name": "koshell",
  "version": "0.1.0",
  "description": "Terminal shell wrapper with a headless xterm mirror.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "start": "node src/index.ts",
    "format": "prettier . --write --list-different",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,cts,mts,json,jsonc,css,scss,md,yml,yaml}": "prettier --write --list-different",
    "*.{js,cjs,mjs,ts,cts,mts}": "eslint --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "diff": "^9.0.0",
    "node-pty": "^1.1.0"
  }
}
