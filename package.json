{
  "name": "koshell",
  "version": "0.1.0",
  "description": "Human-centric shared terminal: Rust terminal-core beside a Bun AI daemon.",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/koshell/koshell.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "bun": ">=1.3"
  },
  "scripts": {
    "format": "prettier . --write --list-different",
    "format:check": "prettier . --check",
    "lint": "bun run --filter './packages/*' lint",
    "typecheck": "bun run --filter './packages/*' typecheck",
    "test": "bun run --filter './packages/*' test",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,cts,mts,json,jsonc,css,scss,md,yml,yaml}": "prettier --write --list-different"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4"
  }
}
